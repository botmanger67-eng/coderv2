"""
Environment Variables Template (.env.example)

This file serves as a template for environment configuration.
Copy this file to .env and fill in the appropriate values.
"""

from typing import Final, Dict, Optional
import os
import sys
from pathlib import Path


class EnvironmentVariableTemplate:
    """
    Template class defining all required and optional environment variables
    for the application.
    """

    # Application Configuration
    APP_NAME: Final[str] = "my_application"
    APP_ENV: Final[str] = "development"  # Options: development, staging, production
    APP_DEBUG: Final[bool] = True
    APP_PORT: Final[int] = 8000
    APP_HOST: Final[str] = "0.0.0.0"
    APP_SECRET_KEY: Final[str] = "change-this-to-a-secure-random-string"
    APP_LOG_LEVEL: Final[str] = "INFO"  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

    # Database Configuration
    DB_ENGINE: Final[str] = "postgresql"  # Options: postgresql, mysql, sqlite
    DB_HOST: Final[str] = "localhost"
    DB_PORT: Final[int] = 5432
    DB_NAME: Final[str] = "my_database"
    DB_USER: Final[str] = "my_user"
    DB_PASSWORD: Final[str] = "my_secure_password"
    DB_POOL_SIZE: Final[int] = 10
    DB_MAX_OVERFLOW: Final[int] = 20
    DB_POOL_TIMEOUT: Final[int] = 30
    DB_ECHO: Final[bool] = False

    # Redis Configuration
    REDIS_HOST: Final[str] = "localhost"
    REDIS_PORT: Final[int] = 6379
    REDIS_PASSWORD: Final[Optional[str]] = None
    REDIS_DB: Final[int] = 0
    REDIS_SOCKET_TIMEOUT: Final[int] = 5
    REDIS_RETRY_ON_TIMEOUT: Final[bool] = True

    # Cache Configuration
    CACHE_TYPE: Final[str] = "redis"  # Options: redis, memory, file
    CACHE_TTL: Final[int] = 300  # Default TTL in seconds
    CACHE_KEY_PREFIX: Final[str] = "myapp:"

    # Authentication & Security
    AUTH_JWT_SECRET: Final[str] = "change-this-to-a-secure-jwt-secret"
    AUTH_JWT_ALGORITHM: Final[str] = "HS256"
    AUTH_JWT_EXPIRATION_HOURS: Final[int] = 24
    AUTH_JWT_REFRESH_EXPIRATION_DAYS: Final[int] = 30
    AUTH_BCRYPT_ROUNDS: Final[int] = 12
    AUTH_SESSION_TIMEOUT_MINUTES: Final[int] = 30
    AUTH_MAX_LOGIN_ATTEMPTS: Final[int] = 5
    AUTH_LOCKOUT_DURATION_MINUTES: Final[int] = 15

    # API Configuration
    API_VERSION: Final[str] = "v1"
    API_PREFIX: Final[str] = "/api/v1"
    API_RATE_LIMIT: Final[int] = 100  # Requests per minute
    API_RATE_LIMIT_WINDOW: Final[int] = 60  # Window in seconds
    API_CORS_ORIGINS: Final[str] = "http://localhost:3000,http://localhost:8080"
    API_CORS_METHODS: Final[str] = "GET,POST,PUT,DELETE,PATCH,OPTIONS"
    API_CORS_HEADERS: Final[str] = "Content-Type,Authorization,X-Requested-With"

    # Email Configuration
    EMAIL_HOST: Final[str] = "smtp.gmail.com"
    EMAIL_PORT: Final[int] = 587
    EMAIL_USER: Final[str] = "your-email@gmail.com"
    EMAIL_PASSWORD: Final[str] = "your-app-specific-password"
    EMAIL_USE_TLS: Final[bool] = True
    EMAIL_USE_SSL: Final[bool] = False
    EMAIL_FROM_ADDRESS: Final[str] = "noreply@myapp.com"
    EMAIL_FROM_NAME: Final[str] = "My Application"

    # File Storage Configuration
    STORAGE_BACKEND: Final[str] = "local"  # Options: local, s3, gcs, azure
    STORAGE_LOCAL_PATH: Final[str] = "./storage"
    STORAGE_S3_BUCKET: Final[str] = "my-bucket"
    STORAGE_S3_REGION: Final[str] = "us-east-1"
    STORAGE_S3_ACCESS_KEY: Final[str] = "your-access-key"
    STORAGE_S3_SECRET_KEY: Final[str] = "your-secret-key"
    STORAGE_MAX_FILE_SIZE: Final[int] = 10485760  # 10MB in bytes
    STORAGE_ALLOWED_EXTENSIONS: Final[str] = "jpg,jpeg,png,gif,pdf,doc,docx"

    # Monitoring & Logging
    MONITORING_ENABLED: Final[bool] = True
    MONITORING_SENTRY_DSN: Final[Optional[str]] = None
    MONITORING_DATADOG_API_KEY: Final[Optional[str]] = None
    MONITORING_DATADOG_APP_KEY: Final[Optional[str]] = None
    LOGGING_FORMAT: Final[str] = "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    LOGGING_DATE_FORMAT: Final[str] = "%Y-%m-%d %H:%M:%S"
    LOGGING_FILE_PATH: Final[str] = "./logs/app.log"
    LOGGING_MAX_BYTES: Final[int] = 10485760  # 10MB
    LOGGING_BACKUP_COUNT: Final[int] = 5

    # External Services
    EXTERNAL_SERVICE_TIMEOUT: Final[int] = 30  # Seconds
    EXTERNAL_SERVICE_RETRY_COUNT: Final[int] = 3
    EXTERNAL_SERVICE_RETRY_DELAY: Final[int] = 1  # Seconds
    EXTERNAL_API_BASE_URL: Final[str] = "https://api.example.com"
    EXTERNAL_API_KEY: Final[str] = "your-external-api-key"

    # Feature Flags
    FEATURE_NEW_UI_ENABLED: Final[bool] = False
    FEATURE_BETA_FEATURES_ENABLED: Final[bool] = False
    FEATURE_ANALYTICS_ENABLED: Final[bool] = True
    FEATURE_NOTIFICATIONS_ENABLED: Final[bool] = True

    # Performance Configuration
    PERFORMANCE_WORKER_COUNT: Final[int] = 4
    PERFORMANCE_MAX_CONNECTIONS: Final[int] = 100
    PERFORMANCE_KEEPALIVE_TIMEOUT: Final[int] = 5
    PERFORMANCE_GZIP_ENABLED: Final[bool] = True
    PERFORMANCE_GZIP_LEVEL: Final[int] = 6
    PERFORMANCE_GZIP_MIN_SIZE: Final[int] = 1000  # Bytes

    # Security Headers
    SECURITY_HSTS_ENABLED: Final[bool] = True
    SECURITY_HSTS_MAX_AGE: Final[int] = 31536000  # 1 year
    SECURITY_XSS_PROTECTION: Final[bool] = True
    SECURITY_CONTENT_SECURITY_POLICY: Final[str] = "default-src 'self'"
    SECURITY_X_FRAME_OPTIONS: Final[str] = "DENY"
    SECURITY_X_CONTENT_TYPE_OPTIONS: Final[str] = "nosniff"

    @classmethod
    def get_required_variables(cls) -> Dict[str, str]:
        """
        Returns a dictionary of required environment variables with descriptions.
        
        Returns:
            Dict[str, str]: Dictionary mapping variable names to descriptions
        """
        return {
            "APP_SECRET_KEY": "Secret key for Flask/Django applications",
            "DB_HOST": "Database server hostname",
            "DB_PORT": "Database server port",
            "DB_NAME": "Database name",
            "DB_USER": "Database username",
            "DB_PASSWORD": "Database password",
            "AUTH_JWT_SECRET": "Secret key for JWT token generation",
            "EMAIL_HOST": "SMTP server hostname",
            "EMAIL_PORT": "SMTP server port",
            "EMAIL_USER": "SMTP username",
            "EMAIL_PASSWORD": "SMTP password",
        }

    @classmethod
    def validate_environment(cls) -> bool:
        """
        Validates that all required environment variables are set.
        
        Returns:
            bool: True if all required variables are set, False otherwise
        """
        missing_vars: list = []
        
        for var_name in cls.get_required_variables():
            if not os.environ.get(var_name):
                missing_vars.append(var_name)
        
        if missing_vars:
            print(f"ERROR: Missing required environment variables: {', '.join(missing_vars)}")
            return False
        
        return True

    @classmethod
    def generate_env_file(cls, filepath: Optional[str] = None) -> None:
        """
        Generates a .env file with default values.
        
        Args:
            filepath: Optional custom filepath for the .env file
        """
        if filepath is None:
            filepath = ".env"
        
        env_path = Path(filepath)
        
        if env_path.exists():
            print(f"WARNING: {filepath} already exists. Overwriting...")
        
        try:
            with open(env_path, 'w') as f:
                f.write("# Environment Configuration File\n")
                f.write("# Copy this file to .env and update values\n\n")
                
                for attr_name in dir(cls):
                    if attr_name.startswith('_') or attr_name == 'get_required_variables' or \
                       attr_name == 'validate_environment' or attr_name == 'generate_env_file':
                        continue
                    
                    attr_value = getattr(cls, attr_name)
                    
                    if isinstance(attr_value, (str, int, bool, type(None))):
                        if attr_value is None:
                            f.write(f"# {attr_name}=\n")
                        elif isinstance(attr_value, bool):
                            f.write(f"{attr_name}={str(attr_value).lower()}\n")
                        else:
                            f.write(f"{attr_name}={attr_value}\n")
                
                print(f"Successfully generated {filepath}")
                
        except IOError as e:
            print(f"ERROR: Failed to write {filepath}: {e}")
            sys.exit(1)


def main() -> None:
    """
    Main entry point for generating the .env.example file.
    """
    try:
        # Generate the .env.example file
        EnvironmentVariableTemplate.generate_env_file(".env.example")
        
        # Validate the current environment (if .env exists)
        if os.path.exists(".env"):
            print("\nValidating current environment...")
            if EnvironmentVariableTemplate.validate_environment():
                print("Environment validation passed.")
            else:
                print("Environment validation failed. Please check your .env file.")
        
    except Exception as e:
        print(f"ERROR: Failed to generate environment template: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()